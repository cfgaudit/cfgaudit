{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(go test ./...)",
      "Edit(src/*)",
      "Read(README.md)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "DEBUG": "true",
    "API_TOKEN": "$API_TOKEN"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "echo running tool", "timeout": 30}
        ]
      }
    ]
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@1.2.3", "/tmp"],
      "alwaysAllow": ["read_file", "list_directory"]
    }
  }
}
